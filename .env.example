# Copy to .env (gitignored). Used by scripts/refresh_nyc_catalog_amenities_prod.sh and check_backend_score.sh.
# HOMEFIT_PROXY_SECRET=from Railway → Variables (required for /score proxy on production).
# HOMEFIT_API_BASE=https://home-fit-production.up.railway.app
#
# Active Outdoors — Google Places supplement when OSM lists are thin (default off).
# HOMEFIT_PLACES_AO_FALLBACK_ENABLED=1
# HOMEFIT_PLACES_AO_LOCAL_TRIGGER_LT=3
# HOMEFIT_PLACES_AO_REGIONAL_SWIM_LT=2
# HOMEFIT_PLACES_AO_REGIONAL_CAMP_LT=1
# HOMEFIT_PLACES_AO_MAX_HTTP_CALLS=3
# HOMEFIT_PLACES_AO_NEAR_DUP_M=85
#
# Social Fabric — Google Places civic fallback when Overpass civic query fails (default off).
# HOMEFIT_PLACES_SF_FALLBACK_ENABLED=1
