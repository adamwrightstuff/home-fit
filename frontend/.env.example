# API (optional; defaults to production)
NEXT_PUBLIC_API_URL=https://home-fit-production.up.railway.app

# Server-side proxy to Railway (same as /api/score). Used by /api/agent/recommend.
# RAILWAY_API_BASE_URL=http://127.0.0.1:8000
# HOMEFIT_PROXY_SECRET=  (must match backend HOMEFIT_PROXY_SECRET in production)

# Supabase Auth (optional; if set, Sign in / Sign up bar and modal are shown)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend (Railway) only — automatic catalog pillar aggregates (see README)
# SUPABASE_SERVICE_ROLE_KEY=  (same project; never commit; used with HOMEFIT_CATALOG_CONTRIBUTIONS_ENABLED)
